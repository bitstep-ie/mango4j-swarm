#!/bin/sh
set -eu

if [ "${MANGO_SWARM_SKIP_VERSION_BUMP:-}" = "1" ]; then
  exit 0
fi

staged_files=$(git diff --cached --name-only)
if [ -z "$staged_files" ]; then
  exit 0
fi

if [ "$staged_files" = "pom.xml" ]; then
  exit 0
fi

scripts/bump-patch-version.py --pom pom.xml >/dev/null
git add pom.xml
